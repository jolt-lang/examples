{:paths ["src"]

 :deps {jolt-lang/glimmer-gl {:local/root "../../glimmer-gl"}
        jolt-lang/glimmer    {:local/root "../../glimmer"}}

 ;; The native libraries — OpenGL (from glimmer-gl) and the GTK4/GLib stack
 ;; (from glimmer) — are declared in those deps' :jolt/native entries and
 ;; merged automatically by jolt's dependency walk, so they are not repeated
 ;; here.

 :aliases {:run   {:main-opts ["-m" "gl-demo.core"]}
           :check {:main-opts ["-m" "gl-demo.check"]}}

 :tasks {run   "joltc -M:run"
         check "joltc -M:check"}}
